# ZenithPulse API
ZENITHPULSE_API_KEY=           # Bearer token for REST API + MCP auth

# Bitget Trading API (required)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Playbook API (getagent-skill)
PLAYBOOK_ACCESS_KEY=           # ACCESS-KEY header for getagent-skill API (optional — mock mode if absent)
PLAYBOOK_MARGIN_BUDGET=100     # Fallback margin budget (USDT) — not in list API response

# Telegram Alerts (optional — alerts disabled if absent)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server Configuration
DB_PATH=./data/zenithpulse.db  # SQLite path (Docker default: /data/zenithpulse.db)
PORT=3001                      # Server port
POLL_INTERVAL_MS=15000         # Observer polling interval (ms)
MODE_DEFAULT=observe           # Default mode: enforce | observe | silent
PAPER_TRADING=false            # Use demo/paper-trading API endpoints
